# Environment variables — copy to .env and fill in values
# ⚠️  Never commit .env to git

# ── Database (AWS RDS MySQL) ─────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_NAME=attendance_db
DB_USER=admin
DB_PASSWORD=your_db_password

# ── AWS IoT Core ─────────────────────────────────────────────────────────────
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxxx-ats.iot.ap-south-1.amazonaws.com
AWS_REGION=ap-south-1
IOT_CERT_PATH=certs/server.crt.pem
IOT_KEY_PATH=certs/server.key.pem
IOT_CA_PATH=certs/AmazonRootCA1.pem

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_strong_random_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
